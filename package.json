{
  "name": "home-assistant",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:server": "cd server && node --watch server.js",
    "dev:client": "cd client && npm run dev",
    "install:all": "cd client && npm install && cd ../server && npm install",
    "build": "cd client && npm run build",
    "start": "cd server && node server.js"
  }
}
